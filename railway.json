{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "n8n",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "startUpTimeout": 300,
    "volumeMounts": [
      {
        "name": "n8n-data",
        "mountPath": "/home/node/.n8n"
      }
    ]
  }
}
