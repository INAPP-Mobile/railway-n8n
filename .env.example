# Environment variables for n8n on Railway
# Every variable below has a working default — secrets are auto-generated.

# N8N_ENCRYPTION_KEY - Encrypts credentials stored in workflows. Set once and never change.
N8N_ENCRYPTION_KEY=

# N8N_PORT - Port n8n listens on (default: 5678, Railway auto-assigns)
N8N_PORT=5678

# GENERIC_TIMEZONE - Timezone for schedule-triggered nodes, e.g. America/New_York
GENERIC_TIMEZONE=UTC

# NODE_ENV - Node.js environment (production for deploy)
NODE_ENV=production

# N8N_BASIC_AUTH_ACTIVE - Enable HTTP basic auth on the n8n UI
N8N_BASIC_AUTH_ACTIVE=false

# N8N_BASIC_AUTH_USER - Basic auth username
N8N_BASIC_AUTH_USER=***

# N8N_BASIC_AUTH_PASSWORD - Basic auth password
N8N_BASIC_AUTH_PASSWORD=***
