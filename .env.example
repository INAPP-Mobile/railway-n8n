# n8n Configuration

# Secret key used for data encryption (REQUIRED - set once and never change)
N8N_ENCRYPTION_KEY=your-encryption-key-here

# Basic Authentication (optional, disable with N8N_BASIC_AUTH_ACTIVE=false)
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

# Timezone for schedule-triggered nodes
GENERIC_TIMEZONE=UTC
